# ----------------------------------------------------------------------------
# Crate & Barrel ASN Tool - configuration
# Copy this file to ".env" and adjust as needed.
#
# NOTE: Grasshopper credentials are entered on the LOGIN SCREEN now, not here.
# Each user signs in with their own Grasshopper email/password and picks the
# environment (Staging or Production). You normally only need PORT + MOCK_MODE.
# ----------------------------------------------------------------------------

# Port the web server listens on
PORT=3000

# ---- Mock login ----
# MOCK_MODE=true  -> the login screen offers a "Continue in mock mode" option
#                    that uses fabricated orders from the uploaded files. No live
#                    API calls. Real sign-in still works too.
# MOCK_MODE=false -> users must sign in with real Grasshopper credentials.
MOCK_MODE=true

# Default cancellation reason recorded in the Grasshopper audit log
CANCEL_REASON=Not on Crate & Barrel delivery file

# Default Retailer ID to scope order lookups to (the Crate & Barrel account).
# Strongly recommended: without it the tool pages through EVERY retailer's
# orders (slow). Can also be entered per-session on the login screen.
# GH_RETAILER_ID=

# ---- Optional ----
# Environment URLs are built in (Staging / Production). Set GH_BASE_URL only to
# override / add a custom environment used as the fallback.
#   Staging    : https://staging.grasshopperlabs.io
#   Production : https://pulsefinalmile.grasshopperlabs.net
# GH_BASE_URL=
