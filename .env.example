# ----------------------------------------------------------------------------
# Crate & Barrel ASN Tool - configuration
# Copy this file to ".env" and adjust as needed.
#
# NOTE: Grasshopper credentials are entered on the LOGIN SCREEN now, not here.
# Each user signs in with their own Grasshopper client id/secret. You normally
# only need PORT + MOCK_MODE.
# ----------------------------------------------------------------------------

# Port the web server listens on
PORT=3000

# ---- Mock login ----
# MOCK_MODE=true  -> DEV ONLY. Login screen offers "Continue in mock mode"
#                    (fabricated orders, no live API calls) and exposes a Staging
#                    environment option for testing.
# MOCK_MODE=false -> PRODUCTION. Users sign in with real Grasshopper credentials.
#                    Single environment only: production
#                    (https://pulsefinalmile.grasshopperlabs.net). No staging.
MOCK_MODE=true

# Default cancellation reason recorded in the Grasshopper audit log
CANCEL_REASON=Not on Crate & Barrel delivery file

# Default Retailer ID to scope order lookups to (the Crate & Barrel account).
# Strongly recommended: without it the tool pages through EVERY retailer's
# orders (slow). Can also be entered per-session on the login screen.
# GH_RETAILER_ID=

# ---- Optional ----
# The production URL (https://pulsefinalmile.grasshopperlabs.net) is built in.
# Set GH_BASE_URL only if you ever need to point at a different host.
# GH_BASE_URL=
